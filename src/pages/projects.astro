---
import Layout from '../layouts/Layout.astro';
import SaudaraHeader from '../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../components/SaudaraFooter.astro';
import Icon from '../../components/Icon.astro';
import { projects } from '../../lib/projects';
import { projectIcon } from '../../lib/icons';

const canonicalUrl = "https://rafiq.biz.id/projects";
const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "CollectionPage",
            "name": "Project Portfolio",
            "description": "Selected website, SEO, e-commerce, media, and platform projects by Rafiq.",
            "url": canonicalUrl,
            "hasPart": projects.map((project) => ({
                "@type": "CreativeWork",
                "name": project.title,
                "url": `https://rafiq.biz.id/projects/${project.slug}`,
                "about": project.industry
            }))
        },
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rafiq.biz.id" },
                { "@type": "ListItem", "position": 2, "name": "Projects", "item": canonicalUrl }
            ]
        }
    ]
};
---

<Layout title="Projects | Rafiq" description="Explore selected website, SEO, e-commerce, media, and platform projects by Rafiq." canonicalUrl={canonicalUrl}>
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    </Fragment>

    <div class="sd">
        <SaudaraHeader />

        <section class="sd-page-hero">
            <div class="sd-badge"><span class="sd-dot"></span><span>{projects.length}+ projects shipped</span></div>
            <h1 class="sd-page-h1">Project <span class="serif">portfolio</span></h1>
            <p class="sd-page-lead">A curated archive of websites, platforms, SEO work, and digital systems built for businesses across different industries.</p>
        </section>

        <section class="sd-section" style="padding-top:40px;">
            <div class="sd-grid-3">
                {projects.map((project) => (
                    <a href={`/projects/${project.slug}`} class="sd-proj">
                        <div class="sd-proj-top">
                            <span class="sd-proj-ic"><Icon name={projectIcon(project)} /></span>
                            <span class="sd-proj-arrow"><Icon name="arrowUpRight" /></span>
                        </div>
                        <p class="sd-proj-industry">{project.industry}</p>
                        <h2 class="sd-card-title">{project.title}</h2>
                        <p class="sd-p" style="margin-bottom:10px;">{project.summary.en}</p>
                        <p class="sd-p" lang="id" style="font-size:13.5px;color:#9ca3af;margin-bottom:16px;">{project.summary.id}</p>
                        <div class="sd-tags">
                            {project.tech.map((t) => <span class="sd-tag">{t}</span>)}
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <SaudaraFooter />
    </div>
</Layout>
