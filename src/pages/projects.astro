---
import Layout from '../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { iconColors, projects } from '../../lib/projects';
---

<Layout title="Projects | Rafiq" description="Explore selected website, SEO, e-commerce, media, and platform projects by Rafiq.">
    <main class="min-h-screen flex flex-col">
        <Navbar client:only="react" />

        <section class="section flex-1">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-12">
                    <div class="badge-brutal mb-5">English first · Bahasa Indonesia second</div>
                    <h1
                        class="text-4xl md:text-5xl font-extrabold mb-4"
                        style="color: var(--foreground); letter-spacing: -0.02em;"
                    >
                        Project <span class="text-accent-pop">Portfolio</span>
                    </h1>
                    <p class="text-lg max-w-3xl mx-auto" style="color: var(--text-secondary);">
                        A curated archive of websites, platforms, SEO work, and digital systems built for different industries.
                    </p>
                    <p class="text-base max-w-3xl mx-auto mt-3" lang="id" style="color: var(--text-secondary);">
                        Arsip terkurasi berisi website, platform, pekerjaan SEO, dan sistem digital untuk berbagai industri.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {projects.map((project, i) => (
                        <a
                            href={`/projects/${project.slug}`}
                            class="card-brutal group block hover:-translate-y-1 transition-transform"
                            style="padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column;"
                        >
                            <div class="flex items-start justify-between mb-3">
                                <div
                                    class="icon-circle"
                                    style={`background: ${iconColors[i % iconColors.length].bg};`}
                                >
                                    <span style="font-size: 1.125rem;">{project.emoji}</span>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5" style="color: var(--text-secondary); transition: transform 0.2s; flex-shrink: 0; margin-top: 2px;"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                            </div>
                            <p class="text-xs font-bold uppercase mb-2" style="color: var(--accent-dark); letter-spacing: 0.08em;">
                                {project.industry}
                            </p>
                            <h2
                                class="text-base font-bold mb-2"
                                style="color: var(--foreground);"
                            >
                                {project.title}
                            </h2>
                            <p
                                class="text-sm leading-relaxed mb-3"
                                style="color: var(--text-secondary);"
                            >
                                {project.summary.en}
                            </p>
                            <p
                                class="text-sm leading-relaxed mb-4 flex-1"
                                lang="id"
                                style="color: var(--text-secondary);"
                            >
                                {project.summary.id}
                            </p>
                            <div class="flex flex-wrap gap-2">
                                {project.tech.map((t) => (
                                    <span class="chip">{t}</span>
                                ))}
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <Footer client:load />
    </main>
</Layout>
