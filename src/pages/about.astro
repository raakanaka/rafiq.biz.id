---
import Layout from '../layouts/Layout.astro';
import SaudaraHeader from '../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../components/SaudaraFooter.astro';
import SaudaraCTA from '../../components/SaudaraCTA.astro';
import Icon from '../../components/Icon.astro';

const skills = [
    { name: "JavaScript", icon: "code" },
    { name: "TypeScript", icon: "braces" },
    { name: "React", icon: "atom" },
    { name: "Astro", icon: "rocket" },
    { name: "Tailwind CSS", icon: "palette" },
    { name: "Node.js", icon: "hexagon" },
    { name: "Git", icon: "git" },
    { name: "UI/UX", icon: "sparkles" },
    { name: "SEO", icon: "search" },
    { name: "Keyword Research", icon: "key" },
    { name: "Analytics", icon: "barChart" },
];

const testimonials = [
    { name: "PT Halo Karya Bersama", role: "LMS Rebranding (HaloExpert)", feedback: "Sistem LMS kami berhasil dirancang ulang dengan sangat lancar. Desain UI/UX baru dari Rafiq sangat intuitif, modern, dan disukai para siswa kami.", initials: "HK" },
    { name: "PT Duta Agensi Mail", role: "Media Optimization (Duniafintech)", feedback: "Performa loading website berita kami naik pesat. Bounce rate turun drastis dan traffic organik Google meroket tajam.", initials: "DM" },
    { name: "Al Khair Tour & Travel", role: "Full Travel Web & SEO", feedback: "Sangat puas dengan pengerjaan website travel kami. Fiturnya lengkap, responsif, dan optimasi SEO lokalnya langsung menembus halaman pertama Google.", initials: "AK" },
];

const canonicalUrl = "https://rafiq.biz.id/about";
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Rafiq",
    "url": canonicalUrl,
    "description": "Get to know Rafiq, Web Developer and SEO Specialist based in Indonesia.",
    "mainEntity": {
        "@type": "Person",
        "name": "Rafiq Al Hafizh Adha",
        "jobTitle": "Web Developer & SEO Specialist",
        "url": "https://rafiq.biz.id"
    }
};
---

<Layout title="About Me | Rafiq" description="Get to know Rafiq, Web Developer & SEO Specialist" canonicalUrl={canonicalUrl}>
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    </Fragment>

    <div class="sd">
        <SaudaraHeader />

        <section class="sd-page-hero">
            <div class="sd-badge"><span class="sd-dot"></span><span>Web Developer &amp; SEO Specialist</span></div>
            <h1 class="sd-page-h1">About <span class="serif">me</span></h1>
            <p class="sd-page-lead">Get to know the person behind the code — and the way I think about fast, search-ready websites.</p>
        </section>

        <!-- BIO -->
        <section class="sd-section" style="padding-top:40px;">
            <div class="sd-card sd-bio">
                <div class="sd-bio-head">
                    <div class="sd-bio-avatar">R</div>
                    <div>
                        <div class="sd-bio-name">Rafiq Al Hafizh Adha</div>
                        <div class="sd-bio-role">Web Developer &amp; SEO Specialist · Indonesia</div>
                    </div>
                </div>
                <p>I'm Rafiq, a Web Developer and SEO Specialist based in Indonesia with 6+ years of experience building responsive, search-optimized websites for agencies, government institutions, and startups — a track record across 20+ client websites, from landing pages to full CMS-driven platforms.</p>
                <p>I combine hands-on front-end and back-end development (PHP, Laravel, React, Next.js, WordPress) with technical and on-page SEO to ship fast, well-structured sites that rank and convert — turning complex problems into elegant, fast-loading solutions.</p>
                <div class="sd-bio-resume">
                    <span>Need a copy of my resume?</span>
                    <a href="/Resume_Rafiq_Al_Hafizh_Adha.pdf" download class="sd-btn" style="padding:11px 20px;font-size:15px;"><Icon name="download" sw={2} /> Download CV / Resume</a>
                </div>
            </div>
        </section>

        <!-- SKILLS -->
        <section class="sd-section alt sd-skills-sec" style="padding-top:56px;">
            <div class="sd-head">
                <h2 class="sd-h2">Skills &amp; <span class="serif">stack</span></h2>
                <p class="sd-sub">The tools and disciplines I work with to ship and grow websites.</p>
            </div>
            <div class="sd-skills">
                {skills.map((s) => <span class="sd-skill"><Icon name={s.icon} /> {s.name}</span>)}
            </div>
        </section>

        <!-- TESTIMONIALS -->
        <section class="sd-section">
            <div class="sd-head">
                <h2 class="sd-h2">What clients <span class="serif">say</span></h2>
                <p class="sd-sub">Real results from business owners who trusted me with their websites and SEO.</p>
            </div>
            <div class="sd-grid-3">
                {testimonials.map((t) => (
                    <div class="sd-card sd-testi">
                        <div class="sd-stars">
                            <Icon name="star" fill="currentColor" stroke="none" />
                            <Icon name="star" fill="currentColor" stroke="none" />
                            <Icon name="star" fill="currentColor" stroke="none" />
                            <Icon name="star" fill="currentColor" stroke="none" />
                            <Icon name="star" fill="currentColor" stroke="none" />
                        </div>
                        <p class="sd-quote">“{t.feedback}”</p>
                        <div class="sd-testi-foot">
                            <div class="sd-avatar">{t.initials}</div>
                            <div>
                                <div class="sd-testi-name">{t.name}</div>
                                <div class="sd-testi-role">{t.role}</div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <SaudaraCTA
            heading1="Like how I"
            heading2="work?"
            text="Tell me about your project and let's build something fast, polished, and built to rank."
        />

        <SaudaraFooter />
    </div>
</Layout>
