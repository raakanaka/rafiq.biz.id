---
import Layout from '../../../layouts/Layout.astro';
import { ALLOWED_SERVICES, SEO_SERVICES } from "../../../../lib/constants";
import { ArrowLeft, ArrowUpRight, CheckCircle2, MapPin } from "lucide-react";

export const prerender = false;

// Set Cache-Control header for Cloudflare Edge CDN to cache the rendered page for 7 days
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=604800, s-maxage=604800, stale-while-revalidate=86400'
);

const { service, ids } = Astro.params;
const resolvedService = service as string;
const idsArray = ids ? ids.split('/') : [];

if (!ALLOWED_SERVICES.includes(resolvedService)) {
  return Astro.redirect('/404');
}

type Region = {
  id: string;
  name: string;
};

async function fetchRegions(level: 'provinces' | 'regencies' | 'districts' | 'villages', parentId?: string): Promise<Region[]> {
  try {
    // Directly query the target domain to avoid 301 redirects
    let url = `https://www.emsifa.com/api-wilayah-indonesia/api/${level}.json`;
    if (parentId && level !== 'provinces') {
      url = `https://www.emsifa.com/api-wilayah-indonesia/api/${level}/${parentId}.json`;
    }

    // Attempt to use Cloudflare Cache API if running in Cloudflare context
    let cache: any;
    try {
      if (typeof caches !== 'undefined') {
        cache = await caches.open('api-regions');
        const cachedResponse = await cache.match(url);
        if (cachedResponse) {
          return await cachedResponse.json();
        }
      }
    } catch (e) {
      // Fail silently if cache is unavailable (e.g. local dev)
    }

    const res = await fetch(url);
    if (!res.ok) return [];
    const data = await res.json();

    // Cache the response locally if Cloudflare Cache API is available
    try {
      if (cache && res.ok) {
        const responseToCache = new Response(JSON.stringify(data), {
          headers: {
            'Content-Type': 'application/json',
            'Cache-Control': 'public, max-age=2592000' // Cache API response for 30 days
          }
        });
        await cache.put(url, responseToCache);
      }
    } catch (e) {
      // Fail silently
    }

    return data;
  } catch (err) {
    return [];
  }
}

function formatString(str: string): string {
  return str.replace(/-/g, " ").replace(/\b\w/g, (l) => l.toUpperCase());
}

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
}

const serviceName = formatString(resolvedService);
const serviceTitle = serviceName.toLowerCase().startsWith('jasa') ? serviceName : `Jasa ${serviceName}`;
const pathNames = idsArray.length > 0 ? idsArray.map(formatString).join(", ") : "Seluruh Indonesia";
const isSeoService = SEO_SERVICES.includes(resolvedService);
const priorityAreaLandingMap: Record<string, { name: string; marketNote: string }> = {
    jakarta: {
        name: "Jakarta",
        marketNote: "Jakarta cocok untuk target bisnis dengan kompetisi pencarian tinggi, B2B, company profile, dan layanan premium yang butuh kredibilitas kuat.",
    },
    medan: {
        name: "Medan",
        marketNote: "Medan cocok untuk bisnis regional Sumatera Utara yang ingin menang di pencarian lokal, Google Maps, dan kata kunci layanan berbasis kota.",
    },
};
const priorityAreaLanding = idsArray.length === 1 ? priorityAreaLandingMap[idsArray[0]] : null;

let currentLevelName = "Seluruh Indonesia";
let items: Region[] = [];
let nextLevelPath = `/${resolvedService}/area`;

if (priorityAreaLanding) {
    currentLevelName = priorityAreaLanding.name;
    items = [];
} else if (idsArray.length === 0) {
    items = await fetchRegions('provinces');
} else if (idsArray.length === 1) {
    const provinces = await fetchRegions('provinces');
    const province = provinces.find(p => slugify(p.name) === idsArray[0]);
    if (!province) return Astro.redirect('/404');
    currentLevelName = province.name;
    items = await fetchRegions('regencies', province.id);
    nextLevelPath = `/${resolvedService}/area/${idsArray[0]}`;
} else if (idsArray.length === 2) {
    const provinces = await fetchRegions('provinces');
    const province = provinces.find(p => slugify(p.name) === idsArray[0]);
    if (!province) return Astro.redirect('/404');
    const regencies = await fetchRegions('regencies', province.id);
    const regency = regencies.find(r => slugify(r.name) === idsArray[1]);
    if (!regency) return Astro.redirect('/404');
    currentLevelName = regency.name;
    items = await fetchRegions('districts', regency.id);
    nextLevelPath = `/${resolvedService}/area/${idsArray[0]}/${idsArray[1]}`;
} else if (idsArray.length === 3) {
    const provinces = await fetchRegions('provinces');
    const province = provinces.find(p => slugify(p.name) === idsArray[0]);
    if (!province) return Astro.redirect('/404');
    const regencies = await fetchRegions('regencies', province.id);
    const regency = regencies.find(r => slugify(r.name) === idsArray[1]);
    if (!regency) return Astro.redirect('/404');
    const districts = await fetchRegions('districts', regency.id);
    const district = districts.find(d => slugify(d.name) === idsArray[2]);
    if (!district) return Astro.redirect('/404');
    currentLevelName = district.name;
    items = await fetchRegions('villages', district.id);
    nextLevelPath = `/${resolvedService}/area/${idsArray[0]}/${idsArray[1]}/${idsArray[2]}`;
} else if (idsArray.length === 4) {
    const provinces = await fetchRegions('provinces');
    const province = provinces.find(p => slugify(p.name) === idsArray[0]);
    if (!province) return Astro.redirect('/404');
    const regencies = await fetchRegions('regencies', province.id);
    const regency = regencies.find(r => slugify(r.name) === idsArray[1]);
    if (!regency) return Astro.redirect('/404');
    const districts = await fetchRegions('districts', regency.id);
    const district = districts.find(d => slugify(d.name) === idsArray[2]);
    if (!district) return Astro.redirect('/404');
    const villages = await fetchRegions('villages', district.id);
    const village = villages.find(v => slugify(v.name) === idsArray[3]);
    if (!village) return Astro.redirect('/404');
    currentLevelName = village.name;
    items = [];
} else {
    return Astro.redirect('/404');
}

let backLink = "";
if (idsArray.length > 0) {
    const backSegments = [...idsArray];
    backSegments.pop();
    backLink = `/${resolvedService}/area${backSegments.length > 0 ? '/' + backSegments.join('/') : ''}`;
}

const fullLocationName = idsArray.map(formatString).join(", ");
const ctaLink = `/${resolvedService}${idsArray.length > 0 ? '/' + idsArray.join('/') : ''}`;

const canonicalUrl = `https://rafiq.biz.id/${resolvedService}/area${idsArray.length > 0 ? '/' + idsArray.join('/') : ''}`;
const titleContent = priorityAreaLanding
    ? `${serviceTitle} ${currentLevelName} | Landing Page Lokasi`
    : `Area Layanan ${serviceName} di ${pathNames} | Direktori Lokasi`;
const descriptionContent = priorityAreaLanding
    ? `Landing page lokasi untuk ${serviceName.toLowerCase()} di ${currentLevelName}. Fokus pada visibilitas lokal, struktur SEO, dan konversi pelanggan dari area ${currentLevelName}.`
    : `Temukan layanan ${serviceName.toLowerCase()} profesional berekspansi hingga ke wilayah ${pathNames}.`;
const isMedanWebsitePricing = priorityAreaLanding?.name === "Medan" && !isSeoService;
const pricingPackages = isSeoService ? [
    {
        badge: "Maps / Lokal",
        name: "SEO Lokal",
        display: "Rp2,5 Juta",
        suffix: "/bulan",
        recommended: false,
        features: ["Audit teknikal on-page", "Optimasi Google Maps", "Riset keyword lokal", "Meta title dan description", "Submit sitemap"],
    },
    {
        badge: "Rekomendasi",
        name: "SEO Bisnis",
        display: "Rp4 Juta",
        suffix: "/bulan",
        recommended: true,
        features: ["Semua fitur SEO Lokal", "Backlink authority bertahap", "2 artikel SEO semantik", "Schema JSON-LD", "Laporan bulanan"],
    },
    {
        badge: "Enterprise",
        name: "SEO VIP",
        display: "Rp6,5 Juta",
        suffix: "/bulan",
        recommended: false,
        features: ["Semua fitur SEO Bisnis", "4+ artikel pilar", "Optimasi struktur kode", "Proteksi spam eksternal", "Konsultasi prioritas"],
    },
] : [
    {
        badge: "UMKM / Personal",
        name: "Starter",
        display: isMedanWebsitePricing ? "Rp2 Juta" : "Rp1,9 Juta",
        suffix: "",
        recommended: false,
        features: ["Custom tema responsif", "Domain dan hosting 1 tahun", "SEO on-page dasar", "Integrasi WhatsApp", "Maksimal 5 halaman"],
    },
    {
        badge: "Rekomendasi",
        name: "Pro",
        display: "Rp3,5 Juta",
        suffix: "",
        recommended: true,
        features: ["Semua fitur Starter", "Desain halaman premium", "Email bisnis profesional", "Schema markup", "Maksimal 10 halaman"],
    },
    {
        badge: "Corporate",
        name: "Premium",
        display: "Rp5,9 Juta",
        suffix: "",
        recommended: false,
        features: ["Semua fitur Pro", "Hosting premium", "Katalog produk atau LMS", "Fitur bilingual", "Analisis konversi"],
    },
];
const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Service",
            "serviceType": serviceTitle,
            "provider": {
                "@type": "Person",
                "name": "Rafiq Al Hafizh Adha",
                "url": "https://rafiq.biz.id",
            },
            "areaServed": {
                "@type": "Place",
                "name": currentLevelName,
            },
            "url": canonicalUrl,
        },
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rafiq.biz.id" },
                { "@type": "ListItem", "position": 2, "name": serviceName, "item": `https://rafiq.biz.id/${resolvedService}` },
                { "@type": "ListItem", "position": 3, "name": currentLevelName, "item": canonicalUrl },
            ],
        },
    ],
};
---

<Layout title={titleContent} description={descriptionContent} canonicalUrl={canonicalUrl} robots="index, follow">
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    </Fragment>

    <main class="min-h-screen flex flex-col bg-background font-body">
      <header class="w-full p-6 border-b border-gray-200 bg-white shadow-sm flex items-center justify-between">
          <a href={`/${resolvedService}`} class="text-xl font-bold font-heading text-foreground" style="text-decoration: none;">
              Rafiq<span class="text-accent-pop">.</span>
          </a>
          <div class="text-sm font-semibold text-text-secondary">
              {priorityAreaLanding ? `Landing Page ${currentLevelName}` : `Direktori ${serviceName}`}
          </div>
      </header>

      <section class="section py-16 flex-1">
        <div class="max-w-5xl mx-auto px-4">
          
          <div class="mb-12">
            {backLink && (
              <a href={backLink} class="inline-flex items-center gap-2 text-accent-dark hover:underline mb-6 font-semibold">
                <ArrowLeft size={16} /> Kembali
              </a>
            )}
            
            <h1 class="text-3xl md:text-5xl font-extrabold text-foreground mb-4">
              {priorityAreaLanding ? serviceTitle : "Cakupan Layanan Web Developer"} di <span class="text-accent">{formatString(currentLevelName.toLowerCase())}</span>
            </h1>
            <p class="text-lg text-text-secondary max-w-2xl leading-relaxed">
              {priorityAreaLanding
                ? `${priorityAreaLanding.marketNote} Halaman ini dibuat sebagai landing page lokasi yang bisa di-index untuk memperkuat pencarian lokal.`
                : "Kami siap membantu bisnis Anda di wilayah ini mendominasi pencarian Google. Eksplorasi hierarki area spesifik Anda, atau klik di bawah untuk melihat penawaran pembuatan Website Company Profile dan Toko Online."
              }
            </p>
          </div>

          {priorityAreaLanding ? (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
              {[
                { title: "Target Keyword Lokal", desc: `Struktur halaman diarahkan untuk query ${serviceName.toLowerCase()} ${currentLevelName}.`, icon: "🎯" },
                { title: "Konten Area Spesifik", desc: "Copywriting dibuat lebih relevan untuk kota target, bukan sekadar halaman umum.", icon: "📍" },
                { title: "Konversi WhatsApp", desc: "CTA diarahkan langsung ke konsultasi agar traffic lokal punya jalur konversi jelas.", icon: "💬" },
              ].map((item) => (
                <div class="card-brutal p-6">
                  <div class="icon-circle mb-4" style="background: var(--accent-light);">
                    <span>{item.icon}</span>
                  </div>
                  <h2 class="text-lg font-bold text-foreground mb-2">{item.title}</h2>
                  <p class="text-text-secondary leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          ) : (
            <div class="card-hard p-8 bg-white mb-12">
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <MapPin className="text-accent" /> Daftar Sub-Wilayah
              </h2>

              {items.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                  {items.map((item) => (
                    <a
                      href={`${nextLevelPath}/${slugify(item.name)}`}
                      class="p-3 border border-gray-200 rounded-md hover:border-accent hover:bg-accent-light transition-colors font-medium text-foreground text-sm flex items-center"
                    >
                      {formatString(item.name.toLowerCase())}
                    </a>
                  ))}
                </div>
              ) : (
                <p class="text-text-secondary italic">Tidak ada pembagian sub-wilayah lebih lanjut.</p>
              )}
            </div>
          )}

          {priorityAreaLanding && (
            <section id="harga" class="mb-12">
              <div class="text-center mb-8">
                <h2 class="text-3xl font-extrabold text-foreground mb-3">
                  Paket Harga <span class="text-accent">Rekomendasi</span>
                </h2>
                <p class="text-text-secondary max-w-2xl mx-auto">
                  Paket Pro/SEO Bisnis direkomendasikan karena paling seimbang antara kebutuhan SEO lokal, kualitas teknis, dan biaya saat komponen domain, hosting, lisensi plugin, API, atau tool premium mengikuti kenaikan kurs USD.
                </p>
                {isMedanWebsitePricing && (
                  <p class="text-sm text-text-secondary mt-3 max-w-2xl mx-auto">
                    Khusus pasar Medan, paket website dimulai dari Rp2 Juta agar tetap kompetitif untuk UMKM lokal tanpa menurunkan standar teknis.
                  </p>
                )}
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
                {pricingPackages.map((pkg) => (
                  <div
                    class={`card-hard flex flex-col p-6 ${pkg.recommended ? 'transform md:-translate-y-3' : 'bg-white'}`}
                    style={pkg.recommended ? 'background: var(--accent-light); border-color: var(--accent-dark);' : ''}
                  >
                    <div class="mb-4 relative">
                      {pkg.recommended && (
                        <div class="absolute -top-3 -right-3 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full border border-border-dark shadow-[2px_2px_0px_#0f172a] transform rotate-3">
                          REKOMENDASI
                        </div>
                      )}
                      <span class={`badge-brutal text-xs mb-4 ${pkg.recommended ? 'bg-white' : ''}`}>{pkg.badge}</span>
                      <h3 class="text-2xl font-bold text-foreground">{pkg.name}</h3>
                    </div>
                    <div class="mb-6 flex items-baseline">
                      <span class="text-3xl font-extrabold text-foreground">{pkg.display}</span>
                      {pkg.suffix && <span class="text-text-secondary ml-2">{pkg.suffix}</span>}
                    </div>
                    <ul class="space-y-3 mb-8 flex-1">
                      {pkg.features.map((feature) => (
                        <li class="flex items-start gap-3 text-text-secondary">
                          <CheckCircle2 className="text-accent flex-shrink-0" size={18} />
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                    <a href={ctaLink} class={`${pkg.recommended ? 'btn-kirim' : 'btn-outline-brutal'} w-full justify-center text-center`}>
                      {pkg.recommended ? 'Ambil Rekomendasi' : 'Lihat Detail'}
                    </a>
                  </div>
                ))}
              </div>
            </section>
          )}

          <div class="text-center bg-accent-light border-2 border-accent-dark p-8 rounded-2xl shadow-[4px_4px_0px_#0f172a]">
            <h3 class="text-2xl font-bold text-foreground mb-4 font-heading">
              Siap mendominasi pasar digital di {fullLocationName || "Seluruh Indonesia"}?
            </h3>
            <p class="mb-8 text-text-secondary">Pesan paket web yang langsung disesuaikan dengan parameter SEO untuk area ini.</p>
            <a href={ctaLink} class="btn-kirim text-lg py-4 px-8 inline-flex hover:-translate-y-1 transition-transform">
              Lihat Penawaran <ArrowUpRight className="ml-2 inline-block" size={20} />
            </a>
          </div>

        </div>
      </section>

      <footer class="w-full py-6 text-center bg-border-dark text-white text-sm">
          <p class="opacity-80">
              &copy; {new Date().getFullYear()} Rafiq Web Developer.
          </p>
      </footer>
    </main>
</Layout>
