---
/**
 * NicheLandingPage.astro
 * Renders a full niche-specific landing page for 48 niches × 98 cities.
 * Imported by [service]/[...location].astro when a niche slug is detected.
 */
import Layout from '../../layouts/Layout.astro';
import SaudaraHeader from '../../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../../components/SaudaraFooter.astro';
import Icon from '../../../components/Icon.astro';
import { CITY_DISPLAY_NAMES } from '../../../lib/constants';
import type { NicheDefinition } from '../../../lib/niches';

interface Props {
  niche: NicheDefinition;
  citySlug: string;
}

const { niche: n, citySlug } = Astro.props;

// Format city name for display
function formatCityName(slug: string): string {
  if (CITY_DISPLAY_NAMES[slug]) return CITY_DISPLAY_NAMES[slug];
  return slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
}

const cityName = formatCityName(citySlug);

// Replace [KOTA] placeholders with actual city name
function r(text: string): string {
  return text.replace(/\[KOTA\]/g, cityName);
}

const whatsappNumber = "6282160731800";
const waMessage = `Halo, saya tertarik dengan jasa website ${n.slug.replace(/-/g, ' ')} di ${cityName}. Boleh info lebih lanjut?`;
const waLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(waMessage)}`;

const canonicalUrl = `https://rafiq.biz.id/jasa-website-${n.slug}-${citySlug}`;
const pageTitle = r(n.title);
const pageDesc = r(n.description);
const pageKeywords = [
  `Jasa Website ${n.slug.replace(/-/g, ' ')}`,
  `website ${n.slug.replace(/-/g, ' ')} ${cityName}`,
  `jasa pembuatan website ${cityName}`,
  "website profesional",
  "SEO friendly",
  `web developer ${cityName}`
];

const nicheDisplayName = n.slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());

function initials(name: string): string {
  return name.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
}

const isEcommerceUmkm = n.slug === "ecommerce-umkm";

const offers = isEcommerceUmkm ? [
  { badge: "UMKM Retail", name: "Paket Basic UMKM", price: "4500000", priceCurrency: "IDR", display: "Rp4,5 Juta", features: ["Desain E-commerce Responsif", "Domain & Hosting (1 Tahun)", "SEO On-Page Dasar", "Bandwidth Unmetered", "Integrasi Payment Gateway", "Katalog Produk Dasar"] },
  { badge: "Toko Grosir & Distributor", name: "Paket Advanced UMKM", price: "7500000", priceCurrency: "IDR", display: "Rp7,5 Juta", isPopular: true, features: ["Semua Fitur Paket Basic", "Setup Google Merchant Shopping", "Email Bisnis Profesional", "Setup Schema Markup / AI Overview", "Katalog Produk Lanjut", "Integrasi Kurir Otomatis"] },
  { badge: "Corporate & Enterprise", name: "Paket Custom Enterprise", price: "12000000", priceCurrency: "IDR", display: "Mulai Rp12 Juta", features: ["Semua Fitur Paket Advanced", "Custom Web Application", "Integrasi ERP / Sistem Kasir", "Dukungan Optimasi Struktur Kode", "Fitur Bilingual", "Dedicated Support"] }
] : [
  { badge: "UMKM / Personal", name: "Paket Starter", price: "1900000", priceCurrency: "IDR", display: "Rp1,9 Juta", features: ["Custom Tema Responsif", "Domain & Hosting (1 Tahun)", "SEO On-Page Dasar", "Bandwidth Unmetered", "Integrasi Tombol WhatsApp", "Maks. 5 Halaman Dasar"] },
  { badge: "Perusahaan / CV", name: "Paket Pro", price: "3500000", priceCurrency: "IDR", display: "Rp3,5 Juta", isPopular: true, features: ["Semua Fitur Paket Starter", "Desain Halaman Khusus Premium", "Email Bisnis Profesional", "Setup Schema Markup / AI Overview", "Maks. 10 Halaman", "Gratis Setup Google My Business"] },
  { badge: "Corporate VIP", name: "Paket Premium", price: "5900000", priceCurrency: "IDR", display: "Rp5,9 Juta", features: ["Semua Fitur Paket Pro", "Server Hosting Premium", "Katalog Produk Lanjut/LMS", "Fitur Bilingual (Dua Bahasa)", "Analisis Konversi", "Revisi Minor Selama Masa Aktif"] },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": `Jasa Website ${nicheDisplayName}`,
      "provider": { "@type": "Organization", "name": "Rafiq Web Developer", "url": "https://rafiq.biz.id" },
      "areaServed": { "@type": "Place", "name": cityName },
      "offers": offers.map(o => ({ "@type": "Offer", "name": o.name, "price": o.price, "priceCurrency": o.priceCurrency }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": n.faq.map(faq => ({ "@type": "Question", "name": r(faq.q), "acceptedAnswer": { "@type": "Answer", "text": r(faq.a) } }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://rafiq.biz.id" },
        { "@type": "ListItem", "position": 2, "name": `Jasa Website ${nicheDisplayName}`, "item": canonicalUrl },
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDesc} keywords={pageKeywords} canonicalUrl={canonicalUrl} robots="index, follow">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="sd">
    <SaudaraHeader />

    <!-- HERO -->
    <section class="sd-page-hero" style="padding-bottom:8px;">
      <div class="sd-badge"><span class="sd-dot"></span><span>{r(n.hero.badge)}</span></div>
      <h1 class="sd-page-h1">
        {r(n.hero.headline).includes(cityName) ? (
          <Fragment>
            {r(n.hero.headline).split(cityName)[0]}<span class="ac">{cityName}</span>{r(n.hero.headline).split(cityName).slice(1).join(cityName)}
          </Fragment>
        ) : (
          <Fragment>{r(n.hero.headline)}</Fragment>
        )}
      </h1>
      <p class="sd-page-lead">{r(n.hero.subheadline)}</p>
      <div class="sd-hero-cta" style="justify-content:center;margin-top:26px;">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="sd-btn">{n.hero.cta} <Icon name="arrowUpRight" /></a>
        <a href="#harga" class="sd-pill-line">Lihat Harga <Icon name="arrowRight" size={16} /></a>
      </div>
    </section>

    <!-- MASALAH & SOLUSI -->
    <section class="sd-section">
      <div class="sd-head">
        <h2 class="sd-h2">Masalah <span class="serif">&amp; Solusi</span></h2>
      </div>
      <div class="sd-grid-2">
        <div class="sd-card">
          <div class="sd-split">
            <div class="sd-ic emoji">⚠️</div>
            <div>
              <h3 class="sd-card-title">Kenapa Bisnis Anda Butuh Website Sekarang?</h3>
              <p class="sd-p">{r(n.problem)}</p>
            </div>
          </div>
        </div>
        <div class="sd-card">
          <div class="sd-split">
            <div class="sd-ic emoji">✅</div>
            <div>
              <h3 class="sd-card-title">Solusi Kami</h3>
              <p class="sd-p">
                Kami membangun website profesional yang dirancang khusus untuk bisnis Anda di {cityName}. Dengan desain premium, optimasi SEO lokal, dan fitur-fitur yang meningkatkan konversi, website Anda akan menjadi mesin penarik pelanggan baru 24/7.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FITUR LAYANAN -->
    <section class="sd-section alt">
      <div class="sd-head">
        <h2 class="sd-h2">Fitur <span class="serif">website</span> yang Anda dapatkan</h2>
        <p class="sd-sub">Fitur lengkap yang dirancang khusus untuk kebutuhan bisnis Anda di {cityName}.</p>
      </div>
      <div class="sd-grid-2">
        {n.features.map(feature => (
          <div class="sd-card">
            <div class="sd-ic emoji">{feature.emoji}</div>
            <h3 class="sd-card-title">{r(feature.title)}</h3>
            <p class="sd-p">{r(feature.description)}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- KEUNGGULAN -->
    <section class="sd-section">
      <div class="sd-head">
        <h2 class="sd-h2">Kenapa <span class="serif">memilih kami?</span></h2>
        <p class="sd-sub">Keunggulan yang membedakan kami dari penyedia jasa website lainnya.</p>
      </div>
      <div class="sd-grid-3">
        {n.usp.map(item => (
          <div class="sd-card">
            <div class="sd-ic emoji">{item.emoji}</div>
            <h3 class="sd-card-title">{r(item.title)}</h3>
            <p class="sd-p">{r(item.description)}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TESTIMONI -->
    <section class="sd-section alt">
      <div class="sd-head">
        <h2 class="sd-h2">Apa kata <span class="serif">klien kami?</span></h2>
        <p class="sd-sub">Testimoni nyata dari klien yang sudah merasakan manfaat website profesional.</p>
      </div>
      <div class="sd-grid-3">
        {n.testimonials.map(t => (
          <div class="sd-card sd-testi">
            <div class="sd-stars">
              <Icon name="star" fill="currentColor" stroke="none" />
              <Icon name="star" fill="currentColor" stroke="none" />
              <Icon name="star" fill="currentColor" stroke="none" />
              <Icon name="star" fill="currentColor" stroke="none" />
              <Icon name="star" fill="currentColor" stroke="none" />
            </div>
            <p class="sd-quote">“{t.text}”</p>
            <div class="sd-testi-foot">
              <div class="sd-avatar">{initials(t.name)}</div>
              <div>
                <div class="sd-testi-name">{t.name}</div>
                <div class="sd-testi-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- HARGA -->
    <section id="harga" class="sd-section">
      <div class="sd-head">
        <h2 class="sd-h2">Paket <span class="serif">harga</span> terbaik</h2>
        <p class="sd-sub">Investasi website profesional yang menghasilkan return berkali lipat lewat pelanggan baru.</p>
        <p class="sd-price-note">
          Paket tengah direkomendasikan untuk mayoritas bisnis karena paling seimbang antara fitur, SEO, dan biaya. Harga dapat menyesuaikan jika domain, hosting premium, lisensi plugin, integrasi API, atau tools berbayar mengikuti kenaikan kurs USD.
        </p>
      </div>
      <div class="sd-grid-3">
        {offers.map(offer => (
          <div class={`sd-card sd-price${offer.isPopular ? ' pop' : ''}`}>
            {offer.isPopular && <span class="sd-price-tag">Terlaris</span>}
            <p class="sd-price-cat">{offer.badge}</p>
            <h3 class="sd-card-title" style="margin-bottom:0;">{offer.name}</h3>
            <div class="sd-price-amount">{offer.display}</div>
            <ul class="sd-price-list">
              {offer.features.map(f => (
                <li><Icon name="check" sw={3} /><span>{f}</span></li>
              ))}
            </ul>
            <a href={waLink} target="_blank" rel="noopener noreferrer" class={offer.isPopular ? 'sd-btn sd-btn-full' : 'sd-pill-line'} style={offer.isPopular ? '' : 'justify-content:center;'}>
              {offer.isPopular ? 'Pilih Paket Kami' : 'Pilih Paket'}{offer.isPopular && <Icon name="arrowRight" />}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="sd-section alt">
      <div class="sd-faq">
        <h2 class="sd-h2" style="margin-bottom:32px;">Pertanyaan <span class="serif">umum</span></h2>
        {n.faq.map(faq => (
          <details class="sd-faq-item">
            <summary>{r(faq.q)}<span class="sd-chev"><Icon name="chevronDown" /></span></summary>
            <div class="sd-faq-a">{r(faq.a)}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- CAKUPAN AREA LOKAL -->
    {cityName && cityName !== "Seluruh Indonesia" && (
      <section class="sd-section">
        <div class="sd-area">
          <h2 class="sd-h2" style="font-size:clamp(22px,2.6vw,30px);">Jangkauan layanan di <span class="serif">{cityName}</span></h2>
          <p>
            Jasa pembuatan website {nicheDisplayName.toLowerCase()} kami menjangkau seluruh area di {cityName} dan sekitarnya, termasuk wilayah {
              cityName.toLowerCase() === "jakarta" ? "Gambir, Kebayoran Baru, Menteng, Kelapa Gading, Senayan, Pantai Indah Kapuk (PIK), Sudirman, Kemang, dan sekitarnya." :
              cityName.toLowerCase() === "medan" ? "Medan Baru, Medan Selayang, Medan Sunggal, Medan Petisah, Medan Helvetia, Medan Kota, Medan Johor, dan sekitarnya." :
              cityName.toLowerCase() === "surabaya" ? "Tunjungan, Gubeng, Wonokromo, Darmo, Sukolilo, Rungkut, Tegalsari, Kenjeran, dan sekitarnya." :
              cityName.toLowerCase() === "bandung" ? "Dago, Pasteur, Gedebage, Coblong, Cihampelas, Braga, Lembang, Buahbatu, dan sekitarnya." :
              `${cityName} Pusat, ${cityName} Utara, ${cityName} Selatan, ${cityName} Barat, ${cityName} Timur, dan area sekitarnya.`
            } Hubungi kami untuk pembuatan website berkinerja tinggi, responsif, dan siap mendominasi pasar lokal Anda.
          </p>
        </div>
      </section>
    )}

    <!-- CTA FINAL -->
    <section class="sd-section">
      <div class="sd-cta" style="justify-content:center;">
        <div class="sd-cta-copy" style="max-width:600px;text-align:center;flex:1 1 auto;">
          <h2 class="sd-cta-h">Siap Membuat Website <span class="ac">{nicheDisplayName}</span><br><span class="serif">di {cityName}?</span></h2>
          <p class="sd-cta-p">Jangan biarkan kompetitor mengambil pelanggan Anda. Konsultasi gratis sekarang dan dapatkan website profesional dalam 7 hari!</p>
          <div class="sd-cta-actions" style="justify-content:center;">
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="sd-btn"><Icon name="messageCircle" /> Hubungi via WhatsApp</a>
          </div>
        </div>
      </div>
    </section>

    <SaudaraFooter />
  </div>

  <a href={waLink} target="_blank" rel="noopener noreferrer" class="sd-wa" aria-label="Hubungi via WhatsApp">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>
