---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SaudaraHeader from '../../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../../components/SaudaraFooter.astro';
import Icon from '../../../components/Icon.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const titleContent = "Blog & Edukasi SEO / Web Development | Rafiq";
const descriptionContent = "Temukan panduan praktis, tips terbaru, dan studi kasus mendalam seputar web development performa tinggi dan strategi SEO organik.";

const fmtDate = (d: Date) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
const isImage = (s?: string) => !!s && s.startsWith('/');
---

<Layout title={titleContent} description={descriptionContent}>
    <div class="sd">
        <SaudaraHeader />

        <section class="sd-page-hero">
            <div class="sd-badge"><span class="sd-dot"></span><span>Blog &amp; edukasi</span></div>
            <h1 class="sd-page-h1">Blog &amp; <span class="serif">insights</span></h1>
            <p class="sd-page-lead">Kumpulan wawasan taktis, riset industri, dan panduan optimasi web untuk membantu bisnis Anda mendominasi pencarian Google.</p>
        </section>

        <section class="sd-section" style="padding-top:40px;">
            {sortedPosts.length === 0 ? (
                <div class="sd-card" style="max-width:440px;margin:0 auto;text-align:center;">
                    <div class="sd-ic" style="margin:0 auto 16px;"><Icon name="newspaper" /></div>
                    <h2 class="sd-card-title">Belum Ada Artikel</h2>
                    <p class="sd-p">Kami sedang meramu artikel baru berkualitas tinggi. Tetap pantau!</p>
                </div>
            ) : (
                <div class="sd-grid-3">
                    {sortedPosts.map((post) => (
                        <a href={`/blog/${post.id}`} class="sd-blog-card">
                            <div class="sd-blog-banner">
                                {isImage(post.data.heroImage)
                                    ? <img src={post.data.heroImage} alt={post.data.title} />
                                    : <Icon name="newspaper" />}
                            </div>
                            <div class="sd-blog-body">
                                <div class="sd-blog-meta">
                                    <div class="sd-tags">
                                        {post.data.tags.slice(0, 2).map((tag) => <span class="sd-tag">{tag}</span>)}
                                    </div>
                                    <span class="sd-blog-date"><Icon name="calendar" sw={1.8} />{fmtDate(post.data.pubDate)}</span>
                                </div>
                                <h2 class="sd-blog-title">{post.data.title}</h2>
                                <p class="sd-blog-desc">{post.data.description}</p>
                                <span class="sd-blog-more">Baca selengkapnya <Icon name="arrowRight" /></span>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </section>

        <SaudaraFooter />
    </div>
</Layout>
