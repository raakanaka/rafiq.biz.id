---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SaudaraHeader from '../../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../../components/SaudaraFooter.astro';
import SaudaraCTA from '../../../components/SaudaraCTA.astro';
import Icon from '../../../components/Icon.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const isImage = post.data.heroImage?.startsWith('/');
const canonicalUrl = `https://rafiq.biz.id/blog/${post.id}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate,
      "url": canonicalUrl,
      "author": {
        "@type": "Person",
        "name": "Rafiq Al Hafizh Adha",
        "url": "https://rafiq.biz.id"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rafiq.biz.id" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://rafiq.biz.id/blog" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalUrl }
      ]
    }
  ]
};
---

<Layout title={`${post.data.title} | Rafiq Blog`} description={post.data.description} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="sd">
    <SaudaraHeader />

    <section class="sd-section" style="padding-top:40px;">
      <div class="sd-article">
        <div style="margin-bottom:28px;">
          <a href="/blog" class="sd-back"><Icon name="arrowLeft" /> Kembali ke Blog</a>
        </div>

        <header>
          <div class="sd-article-tags">
            {post.data.tags.map((tag) => <span class="sd-tag">{tag}</span>)}
            <span class="sd-blog-date"><Icon name="calendar" sw={1.8} />{new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>

          <h1 class="sd-article-h1">{post.data.title}</h1>
          <p class="sd-article-desc">{post.data.description}</p>

          {post.data.heroImage && (
            <div class="sd-article-hero">
              {isImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <Icon name="newspaper" />}
            </div>
          )}
        </header>

        <article class="sd-prose">
          <Content />
        </article>
      </div>
    </section>

    <SaudaraCTA
      heading1="Butuh website cepat"
      heading2="& SEO-optimized?"
      text="Saya bantu desain dan optimasi website agar memuat di bawah 2 detik, menembus halaman pertama Google, dan mengubah trafik jadi pembeli."
    />

    <SaudaraFooter />
  </div>
</Layout>
