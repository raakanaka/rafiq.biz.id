---
import Layout from '../layouts/Layout.astro';
import SaudaraHeader from '../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../components/SaudaraFooter.astro';
import Icon from '../../components/Icon.astro';

const titleContent = "Halaman Tidak Ditemukan (404) | Rafiq";
const descriptionContent = "Maaf, halaman yang Anda cari tidak ditemukan. Kembali ke beranda untuk melihat layanan pembuatan website dan optimasi SEO.";
---

<Layout title={titleContent} description={descriptionContent} robots="noindex, follow">
    <div class="sd">
        <SaudaraHeader />

        <section class="sd-section" style="display:flex;align-items:center;justify-content:center;min-height:64vh;">
            <div class="sd-404">
                <div class="sd-404-orb"><Icon name="search" sw={1.6} /></div>
                <div class="sd-404-code">404</div>
                <h1 class="sd-h2" style="font-size:clamp(24px,3vw,32px);margin-bottom:12px;">Halaman tidak <span class="serif">ditemukan</span></h1>
                <p class="sd-p" style="font-size:16px;max-width:440px;margin:0 auto 28px;">Maaf, halaman yang Anda cari telah dipindahkan, dihapus, atau memang tidak pernah ada. Mari kembali ke jalur yang benar.</p>
                <div class="sd-404-actions">
                    <a href="/" class="sd-btn">Kembali ke beranda</a>
                    <a href="/projects" class="sd-pill-line">Lihat proyek</a>
                    <a href="/blog" class="sd-pill-line">Baca blog</a>
                </div>
            </div>
        </section>

        <SaudaraFooter />
    </div>
</Layout>

<style>
    .sd-404 { text-align: center; max-width: 520px; }
    .sd-404-orb { width: 80px; height: 80px; margin: 0 auto 8px; border-radius: 22px; background: rgba(242,101,34,0.1); color: var(--ac); display: flex; align-items: center; justify-content: center; animation: sdBob 5s ease-in-out infinite; }
    .sd-404-orb svg { width: 38px; height: 38px; }
    .sd-404-code { font-family: 'Encode Sans Expanded'; font-weight: 700; font-size: clamp(64px,12vw,104px); line-height: 1; letter-spacing: -0.03em; color: var(--ac); margin-bottom: 4px; }
    .sd-404-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: center; }
</style>
