---
import Layout from '../layouts/Layout.astro';
import SaudaraHeader from '../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../components/SaudaraFooter.astro';
import SaudaraCTA from '../../components/SaudaraCTA.astro';
import Icon from '../../components/Icon.astro';

const contacts = [
    { title: "Email", value: "rafiq.adha@rafiq.biz.id", href: "mailto:rafiq.adha@rafiq.biz.id", icon: "mail" },
    { title: "WhatsApp", value: "+62 821 6073 1800", href: "https://wa.me/6282160731800", icon: "phone" },
    { title: "LinkedIn", value: "@rafiq-alhafizh-adha", href: "https://linkedin.com/in/rafiq-alhafizh-adha", icon: "linkedin" },
    { title: "GitHub", value: "/raakanaka", href: "https://github.com/raakanaka", icon: "github" },
    { title: "Alt. Email", value: "rafiqalhafizh12@gmail.com", href: "mailto:rafiqalhafizh12@gmail.com", icon: "mail" },
    { title: "Location", value: "Medan, Indonesia", href: null, icon: "mapPin" },
];

const canonicalUrl = "https://rafiq.biz.id/contact";
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Rafiq",
    "url": canonicalUrl,
    "description": "Get in touch with Rafiq for freelance web development, SEO, and digital collaboration.",
    "mainEntity": {
        "@type": "Person",
        "name": "Rafiq Al Hafizh Adha",
        "email": ["rafiq.adha@rafiq.biz.id", "rafiqalhafizh12@gmail.com"],
        "url": "https://rafiq.biz.id",
        "sameAs": [
            "https://github.com/raakanaka",
            "https://linkedin.com/in/rafiq-alhafizh-adha"
        ]
    }
};
---

<Layout title="Contact | Rafiq" description="Get in touch with Rafiq for freelance web development, SEO, and digital collaboration." canonicalUrl={canonicalUrl}>
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    </Fragment>

    <div class="sd">
        <SaudaraHeader />

        <section class="sd-page-hero">
            <div class="sd-badge"><span class="sd-dot"></span><span>Available for freelance</span></div>
            <h1 class="sd-page-h1">Get in <span class="serif">touch</span></h1>
            <p class="sd-page-lead">Ready to start a project? I'm available for freelance work and collaborations. Pick whichever channel suits you — I usually reply within a day.</p>
        </section>

        <section class="sd-section" style="padding-top:40px;padding-bottom:20px;">
            <div class="sd-contact-grid">
                {contacts.map((c) => {
                    const Tag = c.href ? 'a' : 'div';
                    const attrs = c.href ? { href: c.href, target: '_blank', rel: 'noopener noreferrer' } : {};
                    return (
                        <Tag class="sd-contact-card" {...attrs}>
                            <div class="sd-contact-ic"><Icon name={c.icon} /></div>
                            <div>
                                <div class="sd-contact-label">{c.title}</div>
                                <div class="sd-contact-val">{c.value}</div>
                            </div>
                        </Tag>
                    );
                })}
            </div>
        </section>

        <!-- ===== CTA ===== -->
        <SaudaraCTA
            heading1="Prefer to just"
            heading2="start chatting?"
            text="Send a quick message on WhatsApp and tell me about your project. Free consultation — no commitment."
        />

        <SaudaraFooter />
    </div>
</Layout>
