---
import Layout from '../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import HeroStatic from '../../components/HeroStatic.astro';
import ExperienceStatic from '../../components/ExperienceStatic.astro';
import Footer from '../../components/Footer';
import FeaturedProjectsCarousel from '../../components/FeaturedProjectsCarousel';
import Testimonials from '../../components/Testimonials.astro';
import LeadMagnet from '../../components/LeadMagnet';

const homeJsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "ProfessionalService",
            "name": "Rafiq Web Developer & SEO Specialist",
            "image": "https://rafiq.biz.id/favicon.ico",
            "@id": "https://rafiq.biz.id/#service",
            "url": "https://rafiq.biz.id",
            "telephone": "+6282160731800",
            "priceRange": "$$",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Medan",
                "addressLocality": "Medan",
                "addressRegion": "Sumatera Utara",
                "postalCode": "20123",
                "addressCountry": "ID"
            },
            "geo": {
                "@type": "GeoCoordinates",
                "latitude": 3.5952,
                "longitude": 98.6722
            },
            "openingHoursSpecification": {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": [
                    "Monday",
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday"
                ],
                "opens": "09:00",
                "closes": "18:00"
            },
            "sameAs": [
                "https://github.com/raakanaka",
                "https://linkedin.com/in/rafiq-alhafizh-adha"
            ],
            "areaServed": [
                { "@type": "Country", "name": "Indonesia" },
                { "@type": "Place", "name": "Medan" },
                { "@type": "Place", "name": "Jakarta" },
                { "@type": "Place", "name": "Surabaya" },
                { "@type": "Place", "name": "Bandung" }
            ]
        },
        {
            "@type": "Person",
            "name": "Rafiq Al Hafizh Adha",
            "url": "https://rafiq.biz.id",
            "jobTitle": "Web Developer & SEO Specialist",
            "email": "rafiq.adha@rafiq.biz.id",
            "sameAs": [
                "https://github.com/raakanaka",
                "https://linkedin.com/in/rafiq-alhafizh-adha"
            ],
            "knowsAbout": ["Web Development", "SEO", "Astro", "React", "Technical SEO"]
        },
        {
            "@type": "WebSite",
            "name": "Rafiq Portfolio",
            "url": "https://rafiq.biz.id",
            "inLanguage": ["en", "id"]
        }
    ]
};

const skills = [
    { name: "JavaScript", emoji: "⚡" },
    { name: "TypeScript", emoji: "🔷" },
    { name: "React", emoji: "⚛️" },
    { name: "Astro", emoji: "🚀" },
    { name: "Tailwind CSS", emoji: "🎨" },
    { name: "Node.js", emoji: "🟩" },
    { name: "SEO", emoji: "🔍" },
    { name: "UI/UX Design", emoji: "✨" },
];
---

<Layout canonicalUrl="https://rafiq.biz.id">
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(homeJsonLd)} />
    </Fragment>

    <main class="min-h-screen flex flex-col">
        <Navbar client:only="react" />
        <HeroStatic />

        <!-- Divider band -->
        <div class="divider-band"></div>

        <!-- Work Experience -->
        <ExperienceStatic />
        
        <!-- Divider band -->
        <div class="divider-band"></div>

        <!-- Featured Projects -->
        <section class="section" style="background: var(--card-bg)">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-12">
                    <h2 class="text-3xl md:text-4xl font-extrabold mb-3" style="color: var(--foreground); letter-spacing: -0.02em;">
                        Featured <span class="text-accent-pop">Projects</span>
                    </h2>
                    <p style="color: var(--text-secondary); font-size: 1.0625rem;">
                        Rotating highlights from the full project archive
                    </p>
                    <p class="mt-2" lang="id" style="color: var(--text-secondary); font-size: 0.95rem;">
                        Sorotan project bergantian dari arsip portfolio lengkap
                    </p>
                </div>

                <FeaturedProjectsCarousel client:only="react" />
            </div>
        </section>

        <!-- Divider band -->
        <div class="divider-band"></div>

        <!-- Skills -->
        <section class="section">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-12">
                    <h2 class="text-3xl md:text-4xl font-extrabold mb-3" style="color: var(--foreground); letter-spacing: -0.02em;">
                        Skills & <span class="text-accent-pop">Stack</span>
                    </h2>
                    <p style="color: var(--text-secondary); font-size: 1.0625rem;">
                        Technologies I work with daily
                    </p>
                </div>

                <div class="flex flex-wrap justify-center gap-4">
                    {skills.map((skill) => (
                        <div class="badge-brutal" style="font-size: 0.875rem; padding: 8px 16px;">
                            <span>{skill.emoji}</span> {skill.name}
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Divider band -->
        <div class="divider-band"></div>

        <!-- Testimonials -->
        <Testimonials />

        <!-- Lead Magnet (Free Website Audit) -->
        <LeadMagnet client:only="react" />

        <Footer client:load />
    </main>
</Layout>
