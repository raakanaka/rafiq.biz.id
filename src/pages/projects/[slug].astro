---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getProjectNarrative, projects } from '../../../lib/projects';

export const prerender = true;

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const narrative = getProjectNarrative(project);
const pageTitle = `${project.title} Project | Rafiq`;
const pageDescription = project.summary.en;
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={Astro.url.href}>
  <main class="min-h-screen flex flex-col">
    <Navbar client:only="react" />

    <section class="section flex-1" style="background: var(--card-bg);">
      <div class="max-w-6xl mx-auto">
        <div class="mb-10">
          <a href="/projects" class="btn-outline-brutal" style="padding: 0.55rem 1rem; font-size: 0.8125rem;">
            ← Back to Projects
          </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1.35fr_0.65fr] gap-8 items-start">
          <article class="project-detail-panel">
            <div class="flex flex-wrap items-center gap-3 mb-5">
              <span class="project-detail-icon">{project.emoji}</span>
              <span class="badge-brutal">{project.industry}</span>
              <span class="badge-brutal">{project.service}</span>
            </div>

            <p class="text-sm font-bold uppercase mb-3" style="color: var(--accent-dark); letter-spacing: 0.08em;">
              Project Detail
            </p>
            <h1 class="text-4xl md:text-6xl font-extrabold mb-5" style="color: var(--foreground); letter-spacing: -0.02em; line-height: 1;">
              {project.title}
            </h1>

            <div class="project-language-stack">
              <section>
                <div class="language-label">English</div>
                <p class="project-lead">{project.summary.en}</p>
              </section>

              <section lang="id">
                <div class="language-label">Bahasa Indonesia</div>
                <p class="project-lead">{project.summary.id}</p>
              </section>
            </div>
          </article>

          <aside class="project-side-panel">
            <h2 class="text-lg font-extrabold mb-4" style="color: var(--foreground);">
              Project Snapshot
            </h2>
            <dl class="project-meta-list">
              <div>
                <dt>Industry</dt>
                <dd>{project.industry}</dd>
              </div>
              <div>
                <dt>Service</dt>
                <dd>{project.service}</dd>
              </div>
              <div>
                <dt>Website</dt>
                <dd>
                  <a href={project.link} target="_blank" rel="noopener noreferrer nofollow">
                    Visit live project
                  </a>
                </dd>
              </div>
            </dl>
            <div class="flex flex-wrap gap-2 mt-6">
              {project.tech.map((tag) => (
                <span class="chip">{tag}</span>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <div class="divider-band"></div>

    <section class="section">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="project-content-block">
          <div class="language-label">English</div>
          <h2>Professional Context</h2>
          <p>{narrative.en.role}</p>

          <h3>Approach</h3>
          <p>{narrative.en.approach}</p>

          <h3>Outcome</h3>
          <p>{narrative.en.outcome}</p>
        </div>

        <div class="project-content-block" lang="id">
          <div class="language-label">Bahasa Indonesia</div>
          <h2>Konteks Profesional</h2>
          <p>{narrative.id.role}</p>

          <h3>Pendekatan</h3>
          <p>{narrative.id.approach}</p>

          <h3>Hasil</h3>
          <p>{narrative.id.outcome}</p>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--card-bg); padding-top: 4rem; padding-bottom: 4rem;">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-5">
        <div>
          <h2 class="text-2xl md:text-3xl font-extrabold mb-2" style="color: var(--foreground);">
            Explore the original website
          </h2>
          <p style="color: var(--text-secondary);" lang="id">
            Buka website asli project ini untuk melihat konteks publiknya.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/projects" class="btn-outline-brutal">More Projects</a>
          <a href={project.link} target="_blank" rel="noopener noreferrer nofollow" class="btn-kirim">
            Visit Website
          </a>
        </div>
      </div>
    </section>

    <Footer client:load />
  </main>
</Layout>
