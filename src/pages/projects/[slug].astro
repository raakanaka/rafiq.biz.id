---
import Layout from '../../layouts/Layout.astro';
import SaudaraHeader from '../../../components/SaudaraHeader.astro';
import SaudaraFooter from '../../../components/SaudaraFooter.astro';
import SaudaraCTA from '../../../components/SaudaraCTA.astro';
import Icon from '../../../components/Icon.astro';
import { getProjectNarrative, projects } from '../../../lib/projects';
import { projectIcon } from '../../../lib/icons';

export const prerender = true;

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const narrative = getProjectNarrative(project);
const pageTitle = `${project.title} Project | Rafiq`;
const pageDescription = project.summary.en;
const canonicalUrl = `https://rafiq.biz.id/projects/${project.slug}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CreativeWork",
      "name": `${project.title} Project`,
      "description": project.summary.en,
      "url": canonicalUrl,
      "about": project.industry,
      "creator": {
        "@type": "Person",
        "name": "Rafiq Al Hafizh Adha",
        "url": "https://rafiq.biz.id"
      },
      "sameAs": project.link
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rafiq.biz.id" },
        { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://rafiq.biz.id/projects" },
        { "@type": "ListItem", "position": 3, "name": project.title, "item": canonicalUrl }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="sd">
    <SaudaraHeader />

    <section class="sd-section" style="padding-top:40px;">
      <div class="sd-detail-grid">
        <article>
          <div class="sd-detail-badges">
            <span class="sd-detail-icon"><Icon name={projectIcon(project)} /></span>
            <span class="sd-pill-tag">{project.industry}</span>
            <span class="sd-pill-tag">{project.service}</span>
          </div>

          <p class="sd-detail-kicker">Project Detail</p>
          <h1 class="sd-detail-h1">{project.title}</h1>

          <div class="sd-lang">
            <div class="sd-lang-label">English</div>
            <p>{project.summary.en}</p>
          </div>
          <div class="sd-lang" lang="id">
            <div class="sd-lang-label">Bahasa Indonesia</div>
            <p>{project.summary.id}</p>
          </div>
        </article>

        <aside class="sd-snapshot">
          <h2>Project Snapshot</h2>
          <dl>
            <div><dt>Industry</dt><dd>{project.industry}</dd></div>
            <div><dt>Service</dt><dd>{project.service}</dd></div>
            <div><dt>Website</dt><dd><a href={project.link} target="_blank" rel="noopener noreferrer nofollow">Visit live project →</a></dd></div>
          </dl>
          <div class="sd-snapshot-tags">
            {project.tech.map((tag) => <span class="sd-tag">{tag}</span>)}
          </div>
        </aside>
      </div>
    </section>

    <section class="sd-section alt">
      <div class="sd-narrative">
        <div class="sd-prose">
          <div class="sd-lang-label">English</div>
          <h2>Professional Context</h2>
          <p>{narrative.en.role}</p>
          <h3>Approach</h3>
          <p>{narrative.en.approach}</p>
          <h3>Outcome</h3>
          <p>{narrative.en.outcome}</p>
        </div>
        <div class="sd-prose" lang="id">
          <div class="sd-lang-label">Bahasa Indonesia</div>
          <h2>Konteks Profesional</h2>
          <p>{narrative.id.role}</p>
          <h3>Pendekatan</h3>
          <p>{narrative.id.approach}</p>
          <h3>Hasil</h3>
          <p>{narrative.id.outcome}</p>
        </div>
      </div>
    </section>

    <section class="sd-section">
      <div class="sd-card" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:20px;align-items:center;justify-content:space-between;">
        <div>
          <h2 class="sd-card-title" style="font-size:22px;margin-bottom:6px;">Explore the original website</h2>
          <p class="sd-p" lang="id">Buka website asli project ini untuk melihat konteks publiknya.</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:12px;">
          <a href="/projects" class="sd-pill-line">More projects</a>
          <a href={project.link} target="_blank" rel="noopener noreferrer nofollow" class="sd-btn"><Icon name="externalLink" /> Visit website</a>
        </div>
      </div>
    </section>

    <SaudaraCTA
      heading1="Want results"
      heading2="like this?"
      text="Let's build a fast, search-ready website for your business. Free consultation — no commitment."
    />

    <SaudaraFooter />
  </div>
</Layout>
